    <!-- Script xử lý chuyển hướng data thông minh -->
    <script>
        function sendToZalo(event) {
            event.preventDefault();
            const name = document.getElementById('name').value;
            const phone = document.getElementById('phone').value;
            const service = document.getElementById('service').value;
            const note = document.getElementById('note').value;

            // Kỹ thuật chuyển hướng text thẳng sang số Zalo của anh trai để nhận data real-time
            // Thay số điện thoại của anh trai bạn vào đoạn '0901234567' dưới đây
            const adminPhone = '097 900 49 36'; 
            
            const text = `Khách hàng: ${name}\nSĐT: ${phone}\nDịch vụ: ${service}\nGhi chú: ${note}`;
            const encodedText = encodeURIComponent(text);
            
            // Mở link chat Zalo kèm nội dung soạn sẵn
            window.open(`https://zalo.me/${adminPhone}`, '_blank');
            alert('Hệ thống đang kết nối đến Zalo điều xe. Vui lòng bấm gửi tin nhắn để hoàn tất!');
        }
